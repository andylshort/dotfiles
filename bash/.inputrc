# .inputrc

# Use GNU Readline's vi-style keybindings
# Inspired by https://deut-erium.github.io/2024/01/28/inputrc.html
set editing-mode vi
set show-mode-in-prompt on

# Distinguish between command and insert mode
# Prepend [ins] to indicate insert mode and have blinking bar
set vi-ins-mode-string \e[1;30;40m[ins] \1\e[5 q\2\e[0m
# prepend [cmd] to indicate command mode and have a blinking block
set vi-cmd-mode-string \e[1;30;40m[cmd] \1\e[1 q\2\e[0m
set blink-matching-paren on

# ZSH-style autosuggestions
set show-all-if-ambiguous on
TAB:menu-complete

# Partial history search
"\e[A": history-search-backward
"\e[B": history-search-forward
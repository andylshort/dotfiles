#!/bin/bash
# yank - Copies stdin to the system clipboard via OSC 52

# Read standard input
input=$(cat)

# Base64 encode the input and remove newlines
encoded=$(echo -n "$input" | base64 | tr -d '\n')

# Send the OSC 52 escape sequence to the terminal
# If inside tmux, wrap it in a tmux pass-through sequence
if [ -n "$TMUX" ]; then
    printf "\ePtmux;\e\e]52;c;%s\a\e\\" "$encoded"
else
    printf "\e]52;c;%s\a" "$encoded"
fi